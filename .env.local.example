# ── Supabase ─────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER commit, NEVER expose to the browser
# Used only in server-side API routes (admin invite, payouts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────
# Used in invite emails so the callback URL is correct
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe (Phase 2B) ─────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
